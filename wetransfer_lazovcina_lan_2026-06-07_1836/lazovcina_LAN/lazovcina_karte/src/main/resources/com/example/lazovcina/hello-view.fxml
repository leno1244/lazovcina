            <Button text="PRIDRUŽI SE (FIND LAN ROOM)" onAction="#handleJoinGame" style="-fx-background-color: #2a6aaf; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-pref-width: 340; -fx-background-radius: 8; -fx-padding: 10;" />
            <Button text="POGLEDAJ PRAVILA" onAction="#handleShowRules" style="-fx-background-color: gold; -fx-text-fill: black; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 340; -fx-background-radius: 8; -fx-padding: 8;" />
        </VBox>
    </AnchorPane>

    <AnchorPane fx:id="layerEndScreen" visible="false" style="-fx-background-color: rgba(0,0,0,0.9);">
        <VBox alignment="CENTER" spacing="25.0" layoutX="390.0" layoutY="220.0" prefWidth="500.0" style="-fx-background-color: #222; -fx-padding: 40; -fx-background-radius: 20; -fx-border-color: gold; -fx-border-width: 2;">
            <Label text="PARTIJA JE ZAVRŠENA!" style="-fx-text-fill: gold; -fx-font-size: 30px; -fx-font-weight: bold;" />
            <Label fx:id="winnerLabel" text="Placeholder za pobednika" wrapText="true" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-alignment: center;" />
            <Button fx:id="backToMenuButton" text="Nazad u Glavni Meni" onAction="#handleBackToMenuFromEnd" style="-fx-background-color: #3a8a3a; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 8;" />
        </VBox>
    </AnchorPane>
    </children>
</StackPane>